#include <stdio.h>

int main() {
    int choice;
    int number;
    int i;
    while (1) {
        printf("\nSelect an option:\n");
        printf("1. Check if a number is Even or Odd (Conditional Statement)\n");
        printf("2. Print a Countdown (Loops)\n");
        printf("3. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter an integer: ");
                scanf("%d", &number);
                if (number % 2 == 0) {
                    printf("Result: %d is Even.\n", number);
                } else {
                    printf("Result: %d is Odd.\n", number);
                }
                break;

            case 2:
                printf("Enter a starting number for countdown: ");
                scanf("%d", &number);
                printf("Counting down: ");
                for (i = number; i >= 0; i--) {
                    printf("%d ", i);
                }
                printf("\n");
                break;

            case 3:
                printf("Exiting program.);
                return 0;

            default:
                printf("Invalid choice");
        }
    }

    return 0;
}
