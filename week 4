#include <stdio.h>


int addNumbers(int a, int b);

int main() {
    int num1, num2, sum;
    printf("Enter two integers: ");
    scanf("%d %d", &num1, &num2);
    sum = addNumbers(num1, num2);

    printf("The sum is: %d\n", sum);

    return 0;
}
int addNumbers(int a, int b) {
    int result;
    result = a + b;
    return result;
}
