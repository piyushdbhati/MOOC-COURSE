#include <stdio.h> 

int main() {
    int number1, number2, sum;

    printf("Enter first integer: ");
    scanf("%d", &number1); 

    printf("Enter second integer: ");
    scanf("%d", &number2);
 
    sum = number1 + number2;

  
    printf("\nThe sum of %d and %d is: %d\n", number1, number2, sum);

    return 0;
}

